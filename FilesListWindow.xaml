<Window x:Class="MDJMediaPlayer.FilesListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Files List" Height="450" Width="500"
        PreviewKeyDown="Window_PreviewKeyDown"
        ResizeMode="CanMinimize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border CornerRadius="12"
            BorderBrush="{DynamicResource AeroBorderDarkBrush}"
            BorderThickness="1"
            Background="{DynamicResource WindowBackgroundBrush}"
            SnapsToDevicePixels="True">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardAltBackgroundBrush}"
                    CornerRadius="11,11,0,0">
                <DockPanel Margin="4" LastChildFill="True">
                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="MinimizeButton" Style="{StaticResource TitlebarButtonStyle}" Click="MinimizeButton_Click">
                            <Path Data="{StaticResource MinimizeIcon}" Stroke="#FFF" StrokeThickness="2" Width="12" Height="12" />
                        </Button>
                        <Button x:Name="CloseButton" Style="{StaticResource TitlebarButtonStyle}" Click="CloseButton_Click">
                            <Path Data="{StaticResource CloseIcon}" Stroke="#FFF" StrokeThickness="1.5" Width="12" Height="12" />
                        </Button>
                    </StackPanel>

                    <!-- Drag region with window title -->
                    <Grid Background="Transparent" MouseDown="Titlebar_MouseDown">
                        <TextBlock Text="Files List" Foreground="#FFF" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold" />
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Content area -->
            <Grid Grid.Row="1">
                <ListBox x:Name="PlaylistListBox"
                         ItemsSource="{Binding Playlist}"
                         SelectedItem="{Binding Selected, Mode=TwoWay}"
                         IsSynchronizedWithCurrentItem="False"
                         DisplayMemberPath="Title" />
                <TextBlock Text="NO FILES FOUND"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="Gray"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NoVideoFound}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Bottom action bar (kept for convenience) -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,8">
                <Button Content="Open Playlist" Width="88" Margin="0,0,6,0" Padding="6,2" FontSize="11" Click="OpenPlaylistButton_Click" />
                <Button Content="Save Playlist" Width="88" Margin="0,0,6,0" Padding="6,2" FontSize="11" Click="SavePlaylistButton_Click" />
                <Button Content="Add Files" Width="82" Margin="0,0,6,0" Padding="6,2" FontSize="11" Command="{Binding AddFilesCommand}" />
                <Button Content="Clear Playlist" Width="88" Margin="0,0,6,0" Padding="6,2" FontSize="11" Click="ClearPlaylistButton_Click" />
                <Button Content="Close" Width="62" Padding="6,2" FontSize="11" Click="CloseButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

