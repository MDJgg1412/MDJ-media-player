<Window x:Class="MDJMediaPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:MDJMediaPlayer.ViewModels"
        mc:Ignorable="d"
        Title="MDJ Media Player" Height="691" Width="1100" Icon="pack://application:,,,/Assets/app.ico"
        WindowStyle="None" AllowsTransparency="False" Background="{DynamicResource WindowBackgroundBrush}"
        MouseDown="Window_MouseDown"
        PreviewKeyDown="Window_PreviewKeyDown"
        MouseMove="Window_MouseMove"
        MouseLeave="Window_MouseLeave">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <LinearGradientBrush x:Key="AudioWaveRainbowBrush"
                             StartPoint="0.00,0.12"
                             EndPoint="1.00,0.88">
            <GradientStop Color="#FFFF3B30" Offset="0.00" />
            <GradientStop Color="#FFFF9500" Offset="0.14" />
            <GradientStop Color="#FFFFD60A" Offset="0.28" />
            <GradientStop Color="#FF32D74B" Offset="0.42" />
            <GradientStop Color="#FF64D2FF" Offset="0.56" />
            <GradientStop Color="#FF0A84FF" Offset="0.72" />
            <GradientStop Color="#FFBF5AF2" Offset="0.86" />
            <GradientStop Color="#FFFF2D55" Offset="1.00" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AudioWaveRainbowBrushSoft"
                             StartPoint="0.00,0.12"
                             EndPoint="1.00,0.88">
            <GradientStop Color="#AAFF3B30" Offset="0.00" />
            <GradientStop Color="#AAFF9500" Offset="0.14" />
            <GradientStop Color="#AAFFD60A" Offset="0.28" />
            <GradientStop Color="#AA32D74B" Offset="0.42" />
            <GradientStop Color="#AA64D2FF" Offset="0.56" />
            <GradientStop Color="#AA0A84FF" Offset="0.72" />
            <GradientStop Color="#AABF5AF2" Offset="0.86" />
            <GradientStop Color="#AAFF2D55" Offset="1.00" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AudioWaveRainbowRingBrush"
                             StartPoint="0.12,0.00"
                             EndPoint="0.88,1.00">
            <GradientStop Color="#FFFD5E53" Offset="0.00" />
            <GradientStop Color="#FFFFA833" Offset="0.17" />
            <GradientStop Color="#FFFFF275" Offset="0.33" />
            <GradientStop Color="#FF6AFF88" Offset="0.50" />
            <GradientStop Color="#FF7CE7FF" Offset="0.67" />
            <GradientStop Color="#FF6D8CFF" Offset="0.83" />
            <GradientStop Color="#FFC17CFF" Offset="1.00" />
        </LinearGradientBrush>
        <RadialGradientBrush x:Key="VinylRecordBrush"
                             GradientOrigin="0.34,0.32"
                             Center="0.5,0.5"
                             RadiusX="0.5"
                             RadiusY="0.5">
            <GradientStop Color="#FF0B0B0D" Offset="0.00" />
            <GradientStop Color="#FF121317" Offset="0.18" />
            <GradientStop Color="#FF0B0B0D" Offset="0.21" />
            <GradientStop Color="#FF15171C" Offset="0.26" />
            <GradientStop Color="#FF0B0B0D" Offset="0.29" />
            <GradientStop Color="#FF16181D" Offset="0.36" />
            <GradientStop Color="#FF0B0B0D" Offset="0.40" />
            <GradientStop Color="#FF14161A" Offset="0.52" />
            <GradientStop Color="#FF0B0B0D" Offset="0.56" />
            <GradientStop Color="#FF15171B" Offset="0.68" />
            <GradientStop Color="#FF0B0B0D" Offset="0.73" />
            <GradientStop Color="#FF16181D" Offset="0.86" />
            <GradientStop Color="#FF0B0B0D" Offset="1.00" />
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="VinylLabelBrush"
                             GradientOrigin="0.28,0.28"
                             Center="0.5,0.5"
                             RadiusX="0.6"
                             RadiusY="0.6">
            <GradientStop Color="#FF3C7CFF" Offset="0.00" />
            <GradientStop Color="#FF245FDA" Offset="0.55" />
            <GradientStop Color="#FF0F2E6B" Offset="1.00" />
        </RadialGradientBrush>
        <LinearGradientBrush x:Key="VinylGlossBrush"
                             StartPoint="0.05,0.05"
                             EndPoint="0.95,0.95">
            <GradientStop Color="#66FFFFFF" Offset="0.00" />
            <GradientStop Color="#33FFFFFF" Offset="0.32" />
            <GradientStop Color="#00FFFFFF" Offset="0.70" />
        </LinearGradientBrush>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="DjDeckCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#CC182734" />
            <Setter Property="BorderBrush" Value="#8AE7FFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="MinHeight" Value="132" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000"
                                      ShadowDepth="0"
                                      BlurRadius="16"
                                      Opacity="0.22" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#D2213442" />
                    <Setter Property="BorderThickness" Value="1.5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#E62A3E4F" />
                    <Setter Property="BorderThickness" Value="2.2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DjDeckTagStyle" TargetType="Border">
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#21344352" />
        </Style>
        <Style x:Key="DjDeckProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="3" />
            <Setter Property="Background" Value="#BFD8D8D8" />
            <Setter Property="Foreground" Value="#55C9FF" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <DataTemplate x:Key="DjDeckCardTemplate">
            <Border Style="{StaticResource DjDeckCardStyle}"
                    BorderBrush="{Binding Accent}"
                    Opacity="{Binding VisualOpacity}"
                    MouseLeftButtonDown="DjDeckCard_MouseLeftButtonDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="92" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.RowSpan="5"
                            Width="74"
                            Height="74"
                            Margin="0,2,12,0"
                            VerticalAlignment="Top"
                            Padding="0"
                            Background="#1A2531"
                            BorderBrush="{Binding Accent}"
                            BorderThickness="2"
                            IsEnabled="{Binding CanInteract}"
                            Click="DjDeckPlayButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="37">
                                    <Grid>
                                        <Ellipse Margin="5"
                                                 Fill="#0F1820"
                                                 Stroke="#324554"
                                                 StrokeThickness="1" />
                                        <Ellipse Margin="10"
                                                 Stroke="{TemplateBinding BorderBrush}"
                                                 StrokeThickness="2.2"
                                                 Opacity="0.85" />
                                        <Path x:Name="DeckPlayIcon"
                                              Data="{StaticResource PlayIcon}"
                                              Width="18"
                                              Height="18"
                                              Fill="{TemplateBinding BorderBrush}"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                        <Path x:Name="DeckPauseIcon"
                                              Data="{StaticResource PauseIcon}"
                                              Width="18"
                                              Height="18"
                                              Fill="{TemplateBinding BorderBrush}"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Visibility="Collapsed" />
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsPlaying, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                        <Setter TargetName="DeckPlayIcon" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="DeckPauseIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Opacity" Value="0.78" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock Grid.Column="1"
                               Text="{Binding Label}"
                               Foreground="{Binding Accent}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Border Padding="10,3"
                                CornerRadius="11"
                                BorderBrush="{Binding Accent}"
                                BorderThickness="1"
                                Background="#1F2532">
                            <TextBlock Text="{Binding Status}"
                                       Foreground="#FFFFFF"
                                       FontSize="10.5"
                                       FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Text="{Binding Meta}"
                                   Foreground="#B6CBD8"
                                   FontSize="11"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Right" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Margin="0,6,0,0">
                        <TextBlock Text="{Binding TrackTitle}"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Grid Grid.Row="2"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding TrackSubtitle}"
                                   Foreground="#C8D7E0"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1"
                                Content="Add File"
                                Margin="10,0,0,0"
                                Padding="10,2"
                                MinWidth="72"
                                Click="DjDeckAddFileButton_Click" />
                        <Button Grid.Column="2"
                                Content="unload file"
                                Margin="8,0,0,0"
                                Padding="10,2"
                                MinWidth="92"
                                IsEnabled="{Binding CanInteract}"
                                Click="DjDeckUnloadFileButton_Click" />
                    </Grid>

                    <Slider Grid.Row="3"
                            Grid.ColumnSpan="3"
                            Margin="0,12,0,0"
                            Height="18"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding ProgressPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Foreground="{Binding Accent}"
                            Background="#BFD8D8D8"
                            IsEnabled="{Binding CanInteract}"
                            PreviewMouseLeftButtonDown="DjDeckSeekSlider_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="DjDeckSeekSlider_PreviewMouseLeftButtonUp" />

                    <Grid Grid.Row="4"
                          Grid.ColumnSpan="3"
                          Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="#93ACBC"
                                   FontSize="10.5"
                                   Text="{Binding TransportText}" />
                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Margin="0,0,8,0"
                                    Padding="8,2"
                                    MinWidth="84"
                                    IsEnabled="{Binding CanInteract}"
                                    Click="DjDeckReplayButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource ReplayIcon}"
                                          Fill="#FFFFFF"
                                          Stretch="Uniform"
                                          Width="11"
                                          Height="11"
                                          Margin="0,0,6,0" />
                                    <TextBlock Text="Replay"
                                               Foreground="#FFFFFF"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,8,0"
                                    Padding="8,2"
                                    MinWidth="92"
                                    IsEnabled="{Binding CanInteract}"
                                    Click="DjDeckSeparatorsButton_Click">
                                <TextBlock Text="separators"
                                           Foreground="#FFFFFF"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Button>
                            <Button Padding="8,2"
                                    MinWidth="74"
                                    IsEnabled="{Binding CanInteract}"
                                    Click="DjDeckStopButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource StopIcon}"
                                          Fill="#FFFFFF"
                                          Stretch="Uniform"
                                          Width="10"
                                          Height="10"
                                          Margin="0,0,6,0" />
                                    <TextBlock Text="Stop"
                                               Foreground="#FFFFFF"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopBarRow" Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <DockPanel x:Name="TopBar"
                   Grid.Row="0"
                   LastChildFill="True"
                   Background="{DynamicResource CardAltBackgroundBrush}"
                   MouseDown="Titlebar_MouseDown"
                   MouseEnter="TopBar_MouseEnter"
                   MouseLeave="TopBar_MouseLeave">
            <TextBlock Text="MDJ Media Player" Foreground="#FFF" VerticalAlignment="Center" Margin="8,0" FontSize="14" FontWeight="SemiBold" />

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                <Button x:Name="FullscreenButton" Style="{StaticResource TitlebarButtonStyle}" Click="FullscreenButton_Click" ToolTip="Fullscreen">
                    <Path x:Name="FullscreenIconPath"
                          Data="{StaticResource FullscreenIcon}"
                          Fill="Transparent"
                          Stroke="#FFF"
                          StrokeThickness="1.2"
                          Stretch="None"
                          SnapsToDevicePixels="True"
                          StrokeStartLineCap="Square"
                          StrokeEndLineCap="Square"
                          StrokeLineJoin="Miter"
                          Width="12"
                          Height="12" />
                </Button>
                <Button x:Name="MinimizeButton" Style="{StaticResource TitlebarButtonStyle}" Click="MinimizeButton_Click">
                    <Path Data="{StaticResource MinimizeIcon}" Stroke="#FFF" StrokeThickness="2" Width="12" Height="12" />
                </Button>
                <Button x:Name="MaximizeButton" Style="{StaticResource TitlebarButtonStyle}" Click="MaximizeButton_Click">
                    <Path x:Name="MaximizeIconPath"
                          Data="{StaticResource MaximizeIcon}"
                          Fill="Transparent"
                          Stroke="#FFF"
                          StrokeThickness="1.1"
                          Stretch="None"
                          SnapsToDevicePixels="True"
                          Width="12"
                          Height="12" />
                </Button>
                <Button x:Name="CloseButton" Style="{StaticResource TitlebarButtonStyle}" Click="CloseButton_Click">
                    <Path Data="{StaticResource CloseIcon}" Stroke="#FFF" StrokeThickness="1.5" Width="12" Height="12" />
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,6,0">
                <Button Command="{Binding AddFilesCommand}"
                        Content="Add Files"
                        Width="100"
                        Margin="8,0"
                        IsEnabled="{Binding IsDefaultDeckLayout}" />
                <Button x:Name="LoadSubtitleButton"
                        Content="Load Subtitle"
                        Width="110"
                        Margin="8,0"
                        IsEnabled="{Binding IsDefaultDeckLayout}"
                        Click="LoadSubtitleButton_Click" />
                <Button x:Name="FilesListButton"
                        Content="Files List"
                        Width="100"
                        Margin="8,0"
                        IsEnabled="{Binding IsDefaultDeckLayout}"
                        Click="FilesListButton_Click" />
                <Button x:Name="SFXButton" Content="SFX" Width="80" Margin="8,0" Click="SFXButton_Click" />
                <Button x:Name="ExtendedModeButton" Content="Extended Mode" Width="110" Margin="8,0" Click="ExtendedModeButton_Click" />
                <Button x:Name="SettingsButton" Content="Settings" Width="90" Margin="8,0" Click="SettingsButton_Click" />
            </StackPanel>

        </DockPanel>

        <!-- Media area with overlay controls -->
        <Border x:Name="MediaAreaBorder"
                Grid.Row="1"
                Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="10">
            <Grid MouseMove="MediaArea_MouseMove" Background="Transparent">
                <Grid x:Name="MediaHost">
                    <MediaElement Name="mediaElement" LoadedBehavior="Manual" UnloadedBehavior="Manual" Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                </Grid>

                <Grid x:Name="AudioWaveOverlay"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Margin="16"
                      IsHitTestVisible="False"
                      Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.45*" />
                        <ColumnDefinition Width="0.55*" />
                    </Grid.ColumnDefinitions>
                    <Canvas x:Name="AudioWaveOrbCanvas"
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            IsHitTestVisible="False"
                            Visibility="Collapsed" />
                    <Grid x:Name="AudioWaveSpinLayer"
                          Grid.Column="0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform x:Name="AudioWaveSpinTransform" Angle="0" />
                        </Grid.RenderTransform>
                        <Ellipse x:Name="AudioWaveOuterRing"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Width="280"
                                 Height="280"
                                 Fill="{StaticResource VinylRecordBrush}"
                                 Stroke="#1B1B1E"
                                 StrokeThickness="2"
                                 Opacity="0.98">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#000000" ShadowDepth="0" BlurRadius="24" Opacity="0.65" />
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Width="{Binding Width, ElementName=AudioWaveOuterRing}"
                                 Height="{Binding Height, ElementName=AudioWaveOuterRing}"
                                 Stroke="#222226"
                                 StrokeThickness="1"
                                 Opacity="0.35" />
                        <Ellipse HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Width="{Binding Width, ElementName=AudioWaveOuterRing}"
                                 Height="{Binding Height, ElementName=AudioWaveOuterRing}"
                                 Stroke="#1A1A1E"
                                 StrokeThickness="1"
                                 Opacity="0.30"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="0.86" ScaleY="0.86" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Width="{Binding Width, ElementName=AudioWaveOuterRing}"
                                 Height="{Binding Height, ElementName=AudioWaveOuterRing}"
                                 Fill="{StaticResource VinylGlossBrush}"
                                 Opacity="0.42" />
                        <Ellipse x:Name="AudioWaveInnerRing"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Width="236"
                                 Height="236"
                                 Fill="{StaticResource VinylLabelBrush}"
                                 Stroke="#F2F2F2"
                                 StrokeThickness="1.4"
                                 Opacity="0.98" />
                        <Ellipse x:Name="AudioWaveLabelIcon"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Width="{Binding Width, ElementName=AudioWaveInnerRing}"
                                 Height="{Binding Height, ElementName=AudioWaveInnerRing}"
                                 Opacity="0.9"
                                 SnapsToDevicePixels="True"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1.1" ScaleY="1.1" />
                            </Ellipse.RenderTransform>
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="pack://application:,,,/Assets/app.ico"
                                            Stretch="Uniform" />
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Width="{Binding Width, ElementName=AudioWaveInnerRing}"
                                 Height="{Binding Height, ElementName=AudioWaveInnerRing}"
                                 Fill="#FFFFFF"
                                 Opacity="0.10"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="0.72" ScaleY="0.72" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Width="{Binding Width, ElementName=AudioWaveInnerRing}"
                                 Height="{Binding Height, ElementName=AudioWaveInnerRing}"
                                 Fill="#0A0A0C"
                                 Stroke="#F2F2F2"
                                 StrokeThickness="1"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="0.08" ScaleY="0.08" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Path Data="{Binding Data, ElementName=AudioWavePath}"
                              Opacity="0"
                              SnapsToDevicePixels="True"
                              Visibility="Collapsed"
                              Fill="{StaticResource AudioWaveRainbowBrushSoft}">
                            <Path.Effect>
                                <BlurEffect Radius="8" />
                            </Path.Effect>
                        </Path>
                        <Path x:Name="AudioWavePath"
                              StrokeThickness="0"
                              Opacity="0"
                              Visibility="Collapsed"
                              SnapsToDevicePixels="True"
                              Fill="{StaticResource AudioWaveRainbowBrush}" />
                    </Grid>
                    <Border Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Margin="18,0,18,0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource AeroBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="NOW PLAYING"
                                       Foreground="{DynamicResource AeroSubTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Selected.Title, TargetNullValue=No track}"
                                       Foreground="{DynamicResource AeroTextBrush}"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Margin="0,8,0,0"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Selected.FilePath, TargetNullValue=''}"
                                       Foreground="{DynamicResource AeroSubTextBrush}"
                                       FontSize="12"
                                       Margin="0,6,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border x:Name="SubtitleOverlay"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="24,0,24,86"
                        MaxWidth="840"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Visibility="Collapsed"
                        IsHitTestVisible="False">
                    <TextBlock x:Name="SubtitleTextBlock"
                               Foreground="#FFFDFDFD"
                               FontSize="24"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="Subtitle text" />
                </Border>

                <Grid x:Name="DjDeckOverlay"
                      Margin="22"
                      IsHitTestVisible="True"
                      Visibility="{Binding IsDjDeckLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border CornerRadius="24"
                            Background="#73101822"
                            BorderBrush="#4A83A5BF"
                            BorderThickness="1" />
                    <Grid Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="DJ DECK SYSTEM"
                                           Foreground="#F2FFFFFF"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Switch between compact 2-deck and full 4-deck performance views."
                                           Foreground="#B1D0E0EB"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Padding="14,6"
                                    CornerRadius="14"
                                    Background="#28131A22"
                                    BorderBrush="#50728DA3"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding DeckLayout}"
                                           Foreground="#E6F7FF"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.4*" />
                                <ColumnDefinition Width="0.95*" />
                                <ColumnDefinition Width="2.4*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <ContentControl Content="{Binding DjDeckSlots[0]}"
                                                ContentTemplate="{StaticResource DjDeckCardTemplate}" />
                                <ContentControl Content="{Binding DjDeckSlots[2]}"
                                                ContentTemplate="{StaticResource DjDeckCardTemplate}"
                                                Visibility="{Binding IsFourDeckLayout, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Margin="16,0"
                                    Padding="14"
                                    CornerRadius="18"
                                    Background="#F1141921"
                                    BorderBrush="#4B607488"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="MIXER"
                                               Foreground="#EDF7FF"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <Grid Grid.Row="1"
                                          Margin="0,18,0,18"
                                          Visibility="{Binding IsTwoDeckLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock Text="A" Foreground="#55C9FF" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <Slider Orientation="Vertical"
                                                    Height="220"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    Tag="80"
                                                    PreviewMouseDoubleClick="MixerSlider_PreviewMouseDoubleClick"
                                                    Value="{Binding DeckAFader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="B" Foreground="#FF6B6B" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <Slider Orientation="Vertical"
                                                    Height="220"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    Tag="80"
                                                    PreviewMouseDoubleClick="MixerSlider_PreviewMouseDoubleClick"
                                                    Value="{Binding DeckBFader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid Grid.Row="1"
                                          Margin="0,18,0,18"
                                          Visibility="{Binding IsFourDeckLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock Text="A" Foreground="#55C9FF" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <Slider Orientation="Vertical"
                                                    Height="180"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    Tag="80"
                                                    PreviewMouseDoubleClick="MixerSlider_PreviewMouseDoubleClick"
                                                    Value="{Binding DeckAFader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="B" Foreground="#FF6B6B" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <Slider Orientation="Vertical"
                                                    Height="180"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    Tag="80"
                                                    PreviewMouseDoubleClick="MixerSlider_PreviewMouseDoubleClick"
                                                    Value="{Binding DeckBFader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Text="C" Foreground="#62E0A1" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <Slider Orientation="Vertical"
                                                    Height="180"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    Tag="80"
                                                    PreviewMouseDoubleClick="MixerSlider_PreviewMouseDoubleClick"
                                                    Value="{Binding DeckCFader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                            <TextBlock Text="D" Foreground="#F6C15A" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <Slider Orientation="Vertical"
                                                    Height="180"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    Tag="80"
                                                    PreviewMouseDoubleClick="MixerSlider_PreviewMouseDoubleClick"
                                                    Value="{Binding DeckDFader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Row="2"
                                                Margin="0,4,0,0">
                                        <Button x:Name="AdvancedMixerButton"
                                                Content="Advanced Mixer"
                                                Click="AdvancedMixerButton_Click" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <ContentControl Content="{Binding DjDeckSlots[1]}"
                                                ContentTemplate="{StaticResource DjDeckCardTemplate}" />
                                <ContentControl Content="{Binding DjDeckSlots[3]}"
                                                ContentTemplate="{StaticResource DjDeckCardTemplate}"
                                                Visibility="{Binding IsFourDeckLayout, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2"
                                Margin="0,18,0,0"
                                Padding="14,12"
                                CornerRadius="16"
                                Background="#B30E141B"
                                BorderBrush="#40648095"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Current selection"
                                               Foreground="#8FB0C0"
                                               FontSize="11" />
                                    <TextBlock Text="{Binding CurrentDjSelectionText}"
                                               Foreground="#F5FBFF"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Margin="18,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Timeline"
                                               Foreground="#8FB0C0"
                                               FontSize="11"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding CurrentTimeText}"
                                               Foreground="#F5FBFF"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right" />
                                </StackPanel>
                                <StackPanel Grid.Column="2"
                                            Margin="18,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Master Out"
                                               Foreground="#8FB0C0"
                                               FontSize="11"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding MasterOutputText}"
                                               Foreground="#F5FBFF"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- "NO MEDIA FOUND" message -->
                <TextBlock Text="NO MEDIA FOUND"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="Gray">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding NoVideoFound}" Value="True" />
                                        <Condition Binding="{Binding IsDjDeckLayout}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock x:Name="ExtendedModeStatusLabel"
                           Text="EXTENDED MODE"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#CCFFFFFF"
                           Visibility="Collapsed" />

                <!-- Overlay debug/status (moved next to Next button) -->

                <!-- Floating control panel at bottom center -->
                <Border x:Name="ControlPanel" Style="{StaticResource FloatingControlPanel}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,14" MouseEnter="ControlPanel_MouseEnter" MouseLeave="ControlPanel_MouseLeave">
                    <Grid>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" Margin="6">
                        <TextBlock Text="(New file added)" Foreground="LimeGreen" HorizontalAlignment="Center" Margin="0,0,0,4" FontSize="12" Visibility="Collapsed">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNewVideoAvailable}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}" />
                                                            <DiscreteObjectKeyFrame KeyTime="0:0:4" Value="{x:Static Visibility.Collapsed}" />
                                                        </ObjectAnimationUsingKeyFrames>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1" />
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:1" BeginTime="0:0:3" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                            <Button Width="36" Height="36" Command="{Binding StopCommand}" Margin="4">
                                <Path Data="{StaticResource StopIcon}" Fill="#FFF" Stretch="Uniform" Width="14" Height="14" />
                            </Button>
                            <Button Width="36" Height="36" Command="{Binding PrevCommand}" Margin="4">
                                <Path Data="{StaticResource PrevIcon}" Fill="#FFF" Stretch="Uniform" Width="14" Height="14" />
                            </Button>
                            <ToggleButton Width="50" Height="50" IsChecked="{Binding IsPlaying}" Margin="4">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Outer"
                                                Background="{DynamicResource AeroButtonBrush}"
                                                BorderBrush="{DynamicResource AeroBorderDarkBrush}"
                                                BorderThickness="1"
                                                CornerRadius="28"
                                                Width="50"
                                                Height="50">
                                            <Grid>
                                                <Border x:Name="Gloss"
                                                        Background="{DynamicResource AeroButtonGlossBrush}"
                                                        CornerRadius="26"
                                                        Margin="1"
                                                        Opacity="0.45" />
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter Property="Content"><Setter.Value>
                                                    <Path Data="{StaticResource PlayIcon}" Fill="#FFF" Stretch="Uniform" Width="18" Height="18" />
                                                </Setter.Value></Setter>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Content"><Setter.Value>
                                                    <Path Data="{StaticResource PauseIcon}" Fill="#FFF" Stretch="Uniform" Width="18" Height="18" />
                                                </Setter.Value></Setter>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Outer" Property="Background" Value="{DynamicResource AeroButtonHoverBrush}" />
                                                <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AeroBorderBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Outer" Property="Background" Value="{DynamicResource AeroButtonPressedBrush}" />
                                                <Setter TargetName="Gloss" Property="Opacity" Value="0.18" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Button x:Name="NextButton" Width="36" Height="36" Command="{Binding NextCommand}" Margin="4">
                                <Path Data="{StaticResource NextIcon}" Fill="#FFF" Stretch="Uniform" Width="14" Height="14" />
                            </Button>
                            <Button x:Name="SubtitleToggleButton"
                                    Width="62"
                                    Height="36"
                                    Margin="4"
                                    Content="CC"
                                    Click="SubtitleToggleButton_Click"
                                    IsEnabled="False" />
                            <TextBlock x:Name="DebugStatus" Foreground="#FFF" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" Text="No track" />
                        </StackPanel>

                        <!-- Seek and volume -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding CurrentTimeText}" Foreground="#DDD" VerticalAlignment="Center" Margin="8" Grid.Column="0" />
                            <Slider x:Name="PositionSlider"
                                    Minimum="0"
                                    Maximum="{Binding Duration}"
                                    Value="{Binding Position, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    PreviewMouseLeftButtonDown="PositionSlider_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="PositionSlider_PreviewMouseLeftButtonUp" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TotalTimeText}" Foreground="#DDD" VerticalAlignment="Center" Margin="8,0" />
                                <TextBlock Text="Vol" Foreground="#DDD" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <Slider x:Name="VolumeSlider" Width="110" Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="WindowOuterBorder"
                Grid.RowSpan="2"
                BorderBrush="{DynamicResource AeroBorderDarkBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,10,10"
                IsHitTestVisible="False"
                SnapsToDevicePixels="True" />
    </Grid>
</Window>

