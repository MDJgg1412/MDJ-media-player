<Window x:Class="MDJMediaPlayer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings"
        Height="460"
        Width="720"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="AeroTabControlStyle" TargetType="TabControl">
            <Setter Property="TabStripPlacement" Value="Top" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{DynamicResource CardAltBackgroundBrush}"
                                    BorderBrush="{DynamicResource AeroBorderDarkBrush}"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="8,8,0,0"
                                    Padding="6,4,6,2">
                                <TabPanel IsItemsHost="True" />
                            </Border>
                            <Border Grid.Row="1"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource AeroBorderDarkBrush}"
                                    BorderThickness="1,0,1,1"
                                    CornerRadius="0,0,10,10"
                                    Padding="12">
                                <ContentPresenter ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource CardAltBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AeroBorderDarkBrush}" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Panel.ZIndex" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="6,6,0,0"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border x:Name="Gloss"
                                        Background="{DynamicResource AeroButtonGlossBrush}"
                                        CornerRadius="5,5,0,0"
                                        Margin="1"
                                        Opacity="0.18" />
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AeroBorderBrush}" />
                                <Setter Property="Panel.ZIndex" Value="2" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AeroItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AeroBorderDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style x:Key="AppearanceSliderStyle" TargetType="Slider" BasedOn="{StaticResource {x:Type Slider}}">
            <Setter Property="IsEnabled" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Theme}" Value="Zune">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Opacity" Value="0.5" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <ControlTemplate x:Key="ComboBoxToggleTemplate" TargetType="ToggleButton">
            <Border x:Name="ToggleBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
                <Grid>
                    <Path x:Name="Arrow"
                          Data="M 0 0 L 5 5 L 10 0 Z"
                          Fill="{DynamicResource AeroTextBrush}"
                          Width="10"
                          Height="5"
                          HorizontalAlignment="Right"
                          Margin="0,0,10,0"
                          VerticalAlignment="Center" />
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource AeroButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource AeroButtonPressedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource CardAltBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AeroBorderDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource ComboBoxToggleTemplate}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Focusable="False" />
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="10,0,28,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              RecognizesAccessKey="True" />
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder"
                                        Background="{DynamicResource CardAltBackgroundBrush}"
                                        BorderBrush="{DynamicResource AeroBorderDarkBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer Margin="2"
                                                  SnapsToDevicePixels="True"
                                                  CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource CardAltBackgroundBrush}" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="BorderBrush" Value="{DynamicResource AeroBorderDarkBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AeroItemHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource CardAltBackgroundBrush}">
            <DockPanel Margin="4" LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button x:Name="CloseButton" Style="{StaticResource TitlebarButtonStyle}" Click="CloseButton_Click">
                        <Path Data="{StaticResource CloseIcon}" Stroke="#FFF" StrokeThickness="1.5" Width="12" Height="12" />
                    </Button>
                </StackPanel>

                <Grid Background="Transparent" MouseDown="Titlebar_MouseDown">
                    <TextBlock Text="Settings"
                               Foreground="#FFF"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold" />
                </Grid>
            </DockPanel>
        </Grid>

        <TabControl x:Name="SettingsTabs"
                    Grid.Row="1"
                    Style="{StaticResource AeroTabControlStyle}"
                    Margin="12">
            <TabItem Header="Settings">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Settings"
                                   FontFamily="{DynamicResource AppFontFamilyDisplay}"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Tune playback and appearance."
                                   Foreground="White"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SettingsCard}" Grid.Column="0">
                            <StackPanel>
                                <TextBlock Text="Appearance"
                                           Foreground="White"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Theme"
                                           Foreground="White"
                                           FontSize="12"
                                           Margin="0,6,0,0" />
                                <ComboBox SelectedValuePath="Content"
                                          SelectedValue="{Binding Theme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBoxItem Content="Aero" />
                                    <ComboBoxItem Content="Zune" />
                                </ComboBox>
                                <TextBlock Text="Aero colors"
                                           Foreground="White"
                                           FontSize="12"
                                           Margin="0,10,0,0" />
                                <Slider Minimum="0"
                                        Maximum="100"
                                        Style="{StaticResource AppearanceSliderStyle}"
                                        Value="{Binding AeroColorLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Transparency"
                                           Foreground="White"
                                           FontSize="12"
                                           Margin="0,10,0,0" />
                                <Slider Minimum="0"
                                        Maximum="100"
                                        Style="{StaticResource AppearanceSliderStyle}"
                                        Value="{Binding AeroTransparency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Auto hide controls"
                                          Margin="0,10,0,0"
                                          IsChecked="{Binding AutoHideControls, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SettingsCard}" Grid.Column="2">
                            <StackPanel>
                                <TextBlock Text="Media Settings"
                                           Foreground="White"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Playback behavior."
                                           Foreground="White"
                                           FontSize="12"
                                           Margin="0,6,0,0" />
                                <CheckBox Content="Loop media"
                                          IsChecked="{Binding LoopMedia, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Auto select if there is media"
                                          IsChecked="{Binding AutoplayMedia, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Auto next"
                                          IsChecked="{Binding AutoNext, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Loop playlist"
                                          IsChecked="{Binding LoopPlaylist, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="About">
                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <TextBlock x:Name="AboutNameText"
                                   FontFamily="{DynamicResource AppFontFamilyDisplay}"
                                   Text="MDJ Media Player"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="AboutVersionText"
                                   Text="Version"
                                   Foreground="White"
                                   FontSize="12"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="A WPF media player with audio visualizations and playlist support."
                                   Foreground="White"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>




