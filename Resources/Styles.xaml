<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Drop shadow effect -->
    <DropShadowEffect x:Key="DropShadow" BlurRadius="22" ShadowDepth="6" Color="#0B0F14" Opacity="0.55" />

    <!-- Typography -->
    <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="AppFontFamilyDisplay">Segoe UI Semibold</FontFamily>
    <sys:Double x:Key="ControlPanelOpacity">1</sys:Double>
    <sys:Double x:Key="ControlPanelShadowOpacity">0.5</sys:Double>
    <sys:Double x:Key="ControlPanelHazeOpacity">0.25</sys:Double>

    <!-- Aero palette -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#4EC1FF" />
    <SolidColorBrush x:Key="AccentBrush" Color="#7FD2FF" />
    <SolidColorBrush x:Key="AeroBorderBrush" Color="#7FB6E8" />
    <SolidColorBrush x:Key="AeroBorderDarkBrush" Color="#3E5C78" />
    <SolidColorBrush x:Key="AeroTextBrush" Color="#F4FAFF" />
    <SolidColorBrush x:Key="AeroSubTextBrush" Color="#D7E8F7" />

    <!-- Overlay and control brushes -->
    <LinearGradientBrush x:Key="ControlOverlayBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#6B4C6A89" Offset="0.00" />
        <GradientStop Color="#5E3D536D" Offset="0.52" />
        <GradientStop Color="#4A25364C" Offset="1.00" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ControlBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#6E506D8E" Offset="0.00" />
        <GradientStop Color="#5A39506A" Offset="1.00" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ControlPanelHazeBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#90FFFFFF" Offset="0.00" />
        <GradientStop Color="#55FFFFFF" Offset="0.45" />
        <GradientStop Color="#00FFFFFF" Offset="1.00" />
    </LinearGradientBrush>

    <!-- Theme brushes (can be swapped at runtime) -->
    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#263956" Offset="0.00" />
        <GradientStop Color="#101722" Offset="1.00" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PanelBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#2B4162" Offset="0.00" />
        <GradientStop Color="#111A27" Offset="1.00" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#304A6D" Offset="0.00" />
        <GradientStop Color="#162335" Offset="1.00" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardAltBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3A5A81" Offset="0.00" />
        <GradientStop Color="#1B2C43" Offset="1.00" />
    </LinearGradientBrush>

    <!-- Aero buttons -->
    <LinearGradientBrush x:Key="AeroButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3A5D86" Offset="0.00" />
        <GradientStop Color="#1E2F45" Offset="1.00" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AeroButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#4E78A8" Offset="0.00" />
        <GradientStop Color="#24405C" Offset="1.00" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AeroButtonPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1B2B3F" Offset="0.00" />
        <GradientStop Color="#142233" Offset="1.00" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AeroButtonGlossBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#66FFFFFF" Offset="0.00" />
        <GradientStop Color="#22FFFFFF" Offset="0.45" />
        <GradientStop Color="#00FFFFFF" Offset="1.00" />
    </LinearGradientBrush>

    <!-- List selection -->
    <LinearGradientBrush x:Key="AeroSelectionBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#6BAED9" Offset="0.00" />
        <GradientStop Color="#34618C" Offset="1.00" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AeroItemHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3D5F82" Offset="0.00" />
        <GradientStop Color="#2A3F57" Offset="1.00" />
    </LinearGradientBrush>

    <!-- Button style -->
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AeroTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource AeroButtonBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AeroBorderDarkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Outer"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <Grid>
                            <Border x:Name="Gloss"
                                    Background="{DynamicResource AeroButtonGlossBrush}"
                                    CornerRadius="9"
                                    Margin="1"
                                    Opacity="0.45" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Background" Value="{DynamicResource AeroButtonHoverBrush}" />
                            <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AeroBorderBrush}" />
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#4EC1FF" BlurRadius="16" Opacity="0.5" ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Outer" Property="Background" Value="{DynamicResource AeroButtonPressedBrush}" />
                            <Setter TargetName="Gloss" Property="Opacity" Value="0.18" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
    </Style>

    <!-- Titlebar small icon button style -->
    <Style x:Key="TitlebarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="Background" Value="{DynamicResource AeroButtonBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AeroBorderDarkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Outer"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Background" Value="{DynamicResource AeroButtonHoverBrush}" />
                            <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AeroBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Outer" Property="Background" Value="{DynamicResource AeroButtonPressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Floating control panel style (overlay on video) -->
    <Style x:Key="FloatingControlPanel" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ControlOverlayBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AeroBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Margin" Value="8" />
        <Setter Property="Opacity" Value="{DynamicResource ControlPanelOpacity}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Color="#0B0F14" Opacity="{DynamicResource ControlPanelShadowOpacity}" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToggleButton style for play/pause -->
    <Style TargetType="ToggleButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Outer"
                            Background="{DynamicResource AeroButtonBrush}"
                            BorderBrush="{DynamicResource AeroBorderDarkBrush}"
                            BorderThickness="1"
                            CornerRadius="40"
                            Width="64"
                            Height="64">
                        <Grid>
                            <Border x:Name="Gloss"
                                    Background="{DynamicResource AeroButtonGlossBrush}"
                                    CornerRadius="38"
                                    Margin="1"
                                    Opacity="0.45" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Background" Value="{DynamicResource AeroButtonHoverBrush}" />
                            <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AeroBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Outer" Property="Background" Value="{DynamicResource AeroButtonPressedBrush}" />
                            <Setter TargetName="Gloss" Property="Opacity" Value="0.18" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AeroTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AeroBorderDarkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="Foreground" Value="{DynamicResource AeroTextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AeroItemHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AeroSelectionBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AeroBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Menu">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AeroTextBrush}" />
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource AeroTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="8,4" />
        <Style.Triggers>
            <Trigger Property="Role" Value="SubmenuItem">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AeroBorderDarkBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AeroItemHoverBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AeroBorderBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Slider uses default system template elsewhere to ensure correct behavior and visuals -->

    <!-- Converters -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

</ResourceDictionary>

