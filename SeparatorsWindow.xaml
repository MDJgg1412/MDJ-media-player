<Window x:Class="MDJMediaPlayer.SeparatorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="separators"
        Height="286"
        Width="430"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="12"
            BorderBrush="{DynamicResource AeroBorderDarkBrush}"
            BorderThickness="1"
            Background="{DynamicResource WindowBackgroundBrush}"
            SnapsToDevicePixels="True">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource CardAltBackgroundBrush}"
                    CornerRadius="11,11,0,0">
                <DockPanel Margin="4"
                           LastChildFill="True"
                           Background="Transparent">
                    <StackPanel Orientation="Horizontal"
                                DockPanel.Dock="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource TitlebarButtonStyle}"
                                Click="MinimizeButton_Click">
                            <Path Data="{StaticResource MinimizeIcon}"
                                  Stroke="#FFF"
                                  StrokeThickness="2"
                                  Width="12"
                                  Height="12" />
                        </Button>
                        <Button x:Name="CloseButton"
                                Style="{StaticResource TitlebarButtonStyle}"
                                Click="CloseButton_Click">
                            <Path Data="{StaticResource CloseIcon}"
                                  Stroke="#FFF"
                                  StrokeThickness="1.5"
                                  Width="12"
                                  Height="12" />
                        </Button>
                    </StackPanel>

                    <Grid Background="Transparent"
                          MouseDown="Titlebar_MouseDown">
                        <TextBlock x:Name="WindowTitleText"
                                   Text="separators"
                                   Foreground="#FFF"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                    </Grid>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock x:Name="DeckLabelText"
                               Text="Deck"
                               Foreground="{DynamicResource AeroAccentBrush}"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Adjust the stem level mix."
                               Foreground="{DynamicResource AeroSubTextBrush}"
                               FontSize="11"
                               Margin="0,2,0,0" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="95" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Vocal"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="12" />
                    <Slider x:Name="VocalSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="100"
                            Value="100"
                            Margin="8,0,8,0"
                            TickFrequency="5"
                            IsMoveToPointEnabled="True"
                            ValueChanged="StemSlider_ValueChanged" />
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="White"
                               FontSize="12"
                               Text="{Binding ElementName=VocalSlider, Path=Value, StringFormat={}{0:0}}" />
                </Grid>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="95" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Intrumental"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="12" />
                    <Slider x:Name="IntrumentalSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="100"
                            Value="100"
                            Margin="8,0,8,0"
                            TickFrequency="5"
                            IsMoveToPointEnabled="True"
                            ValueChanged="StemSlider_ValueChanged" />
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="White"
                               FontSize="12"
                               Text="{Binding ElementName=IntrumentalSlider, Path=Value, StringFormat={}{0:0}}" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
